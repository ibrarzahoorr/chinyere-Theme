{%- liquid
    assign images_per_row = section.settings.images_per_row | default: '5'
    assign item_limit = section.settings.instagram_item_limit | default: 5
    assign grid_gap = section.settings.grid_gap | times: 0.5 | append: 'px'
    assign scroll_speed = section.settings.scroll_speed | default: 20
    assign image_size = section.settings.image_size | default: 250
    assign image_shape = section.settings.image_shape | default: 'square'
    
    # Typography variables
    assign title_font_size_desktop = section.settings.title_font_size_desktop | default: 32
    assign title_font_size_mobile = section.settings.title_font_size_mobile | default: 24
    assign description_font_size_desktop = section.settings.description_font_size_desktop | default: 16
    assign description_font_size_mobile = section.settings.description_font_size_mobile | default: 14
    assign title_font_weight = section.settings.title_font_weight | default: '600'
    assign description_font_weight = section.settings.description_font_weight | default: '400'
-%}

<div class="instagram-feed section-{{ section.id }} text-center" style="
    --grid-gap: {{ grid_gap }}; 
    --image-size: {{ image_size }}px;
    --item-gap: {{ section.settings.grid_gap }}px;
    --scroll-speed: {{ scroll_speed }}s;
    --title-font-size-desktop: {{ title_font_size_desktop }}px;
    --title-font-size-mobile: {{ title_font_size_mobile }}px;
    --description-font-size-desktop: {{ description_font_size_desktop }}px;
    --description-font-size-mobile: {{ description_font_size_mobile }}px;
    --title-font-weight: {{ title_font_weight }};
    --description-font-weight: {{ description_font_weight }};">
    
    {%- if section.settings.instagram_title != blank -%}
        <h2 class="instagram-title">{{ section.settings.instagram_title }}</h2>
    {%- endif -%}

    {%- if section.settings.instagram_des != blank -%}
        <p class="instagram-description">{{ section.settings.instagram_des }}</p>
    {%- endif -%}

    <div class="instagram-scroll-container">
        <div class="instagram-infinite-scroll {{ image_shape }}">
            {%- comment %} First set of images {% endcomment -%}
            {%- for block in section.blocks limit: item_limit -%}
                {%- if block.settings.image != blank -%}
                    <div class="instagram-item">
                        {%- assign image = block.settings.image -%}
                        
                        {%- comment %} Determine link {% endcomment -%}
                        {%- assign image_link = blank -%}
                        {%- if block.settings.custom_link != blank -%}
                            {%- assign image_link = block.settings.custom_link -%}
                        {%- elsif block.settings.instagram_url != blank -%}
                            {%- assign image_link = block.settings.instagram_url -%}
                        {%- endif -%}

                        <a href="{{ image_link | default: '#' }}" 
                           {% if image_link != blank %}target="_blank"{% endif %}
                           class="instagram-image-link">
                            {{ image | image_url: width: 600 | image_tag: 
                                loading: 'lazy', 
                                class: 'instagram-image', 
                                alt: image.alt | escape 
                            }}
                        </a>

                        {%- if block.settings.title != blank -%}
                            <div class="instagram-item-title">{{ block.settings.title }}</div>
                        {%- endif -%}
                    </div>
                {%- endif -%}
            {%- endfor -%}
            
            {%- comment %} Add more duplicates for truly seamless scrolling {% endcomment -%}
            {%- for block in section.blocks limit: item_limit -%}
                {%- if block.settings.image != blank -%}
                    <div class="instagram-item">
                        {%- assign image = block.settings.image -%}
                        
                        {%- comment %} Determine link {% endcomment -%}
                        {%- assign image_link = blank -%}
                        {%- if block.settings.custom_link != blank -%}
                            {%- assign image_link = block.settings.custom_link -%}
                        {%- elsif block.settings.instagram_url != blank -%}
                            {%- assign image_link = block.settings.instagram_url -%}
                        {%- endif -%}

                        <a href="{{ image_link | default: '#' }}" 
                           {% if image_link != blank %}target="_blank"{% endif %}
                           class="instagram-image-link">
                            {{ image | image_url: width: 600 | image_tag: 
                                loading: 'lazy', 
                                class: 'instagram-image', 
                                alt: image.alt | escape 
                            }}
                        </a>

                        {%- if block.settings.title != blank -%}
                            <div class="instagram-item-title">{{ block.settings.title }}</div>
                        {%- endif -%}
                    </div>
                {%- endif -%}
            {%- endfor -%}
                        
            {%- comment %} Third set for extra smoothness {% endcomment -%}
            {%- for block in section.blocks limit: item_limit -%}
                {%- if block.settings.image != blank -%}
                    <div class="instagram-item">
                        {%- assign image = block.settings.image -%}
                        
                        {%- comment %} Determine link {% endcomment -%}
                        {%- assign image_link = blank -%}
                        {%- if block.settings.custom_link != blank -%}
                            {%- assign image_link = block.settings.custom_link -%}
                        {%- elsif block.settings.instagram_url != blank -%}
                            {%- assign image_link = block.settings.instagram_url -%}
                        {%- endif -%}

                        <a href="{{ image_link | default: '#' }}" 
                           {% if image_link != blank %}target="_blank"{% endif %}
                           class="instagram-image-link">
                            {{ image | image_url: width: 600 | image_tag: 
                                loading: 'lazy', 
                                class: 'instagram-image', 
                                alt: image.alt | escape 
                            }}
                        </a>

                        {%- if block.settings.title != blank -%}
                            <div class="instagram-item-title">{{ block.settings.title }}</div>
                        {%- endif -%}
                    </div>
                {%- endif -%}
            {%- endfor -%}
        </div>
    </div>
</div>

<style>
/* Instagram Feed - Full Width Edge-to-Edge Styling */
.instagram-feed {
    width: 100%;
    max-width: 100vw;
    padding: 0;
    box-sizing: border-box;
    margin: 0;
    overflow: hidden;
}

/* Remove default section padding */
.section-{{ section.id }} {
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
}

/* Typography Styles */
.instagram-feed .instagram-title {
    font-size: var(--title-font-size-desktop, 32px);
    font-weight: var(--title-font-weight, 600);
    line-height: 1.2;
    margin: 20px auto;
    text-align: center;
    color: var(--title-color, #222);
    width: 100%;
}

.instagram-feed .instagram-description {
    font-size: var(--description-font-size-desktop, 16px);
    font-weight: var(--description-font-weight, 400);
    line-height: 1.5;
    color: var(--description-color, #666);
    max-width: 800px;
    margin: 0 auto 30px auto;
    text-align: center;
}

/* Infinite Scroll Container - Full Width */
.instagram-scroll-container {
    overflow: hidden;
    position: relative;
    width: 100%;
    margin: 0;
    padding: 0;
}

/* Infinite Scroll Animation - IMPROVED FOR SEAMLESS LOOPING */
.instagram-infinite-scroll {
    display: flex;
    width: max-content;
    animation: infinite-scroll calc(var(--scroll-speed, 20s) * 10) linear infinite;
    gap: var(--item-gap, 20px);
    padding: 10px 0;
    will-change: transform; /* Performance optimization */
    position: relative;
}

/* Pause on Hover Effect */
.instagram-scroll-container:hover .instagram-infinite-scroll {
    animation-play-state: paused;
}

/* Instagram Item Styling */
.instagram-item {
    flex: 0 0 auto;
    width: var(--image-size, 250px);
    margin: 0;
    transform: translateZ(0); /* Hardware acceleration */
}

/* Instagram Item Title */
.instagram-item-title {
    margin-top: 8px;
    font-size: 14px;
    text-align: center;
}

/* Image Link Styling */
.instagram-image-link {
    display: block;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease;
}

/* Hover Effects */
.instagram-image-link:hover {
    transform: scale(1.05);
    z-index: 2;
}

/* Image Styling */
.instagram-image {
    display: block;
    object-fit: cover;
    width: 100%;
    height: 100%;
    backface-visibility: hidden; /* Prevents flickering during animations */
}

/* Image Shape Variations */
.square .instagram-image-link {
    aspect-ratio: 1 / 1;
}

.circle .instagram-image-link {
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    overflow: hidden;
}

.rounded .instagram-image-link {
    border-radius: 15px;
    overflow: hidden;
}

/* ANIMATION EXTENDED FOR 10 COMPLETE SCROLLS BEFORE RESET */
@keyframes infinite-scroll {
    0% {
        transform: translateX(0);
    }
    10% {
        transform: translateX(calc(-50% * 1));
    }
    20% {
        transform: translateX(calc(-50% * 2));
    }
    30% {
        transform: translateX(calc(-50% * 3));
    }
    40% {
        transform: translateX(calc(-50% * 4));
    }
    50% {
        transform: translateX(calc(-50% * 5));
    }
    60% {
        transform: translateX(calc(-50% * 6));
    }
    70% {
        transform: translateX(calc(-50% * 7));
    }
    80% {
        transform: translateX(calc(-50% * 8));
    }
    90% {
        transform: translateX(calc(-50% * 9));
    }
    100% {
        transform: translateX(calc(-50% * 10));
    }
}

/* Responsive Adjustments */
@media (max-width: 992px) {
    .instagram-feed .instagram-title {
        font-size: var(--title-font-size-tablet, 28px);
    }
    
    .instagram-feed .instagram-description {
        font-size: var(--description-font-size-tablet, 15px);
    }
}

@media (max-width: 768px) {
    .instagram-feed .instagram-title {
        font-size: var(--title-font-size-mobile, 24px);
    }
    
    .instagram-feed .instagram-description {
        font-size: var(--description-font-size-mobile, 14px);
    }
    
    .instagram-item {
        width: calc(var(--image-size, 250px) * 0.8);
    }
    
    .instagram-infinite-scroll {
        gap: calc(var(--item-gap, 20px) * 0.75);
    }
}

@media (max-width: 480px) {
    .instagram-item {
        width: calc(var(--image-size, 250px) * 0.6);
    }
    
    .instagram-infinite-scroll {
        gap: calc(var(--item-gap, 20px) * 0.5);
    }
}
</style>

{% schema %}
{
    "name": "Instagram Feed",
    "settings": [
        {
            "type": "header",
            "content": "Title Settings"
        },
        {
            "type": "text",
            "id": "instagram_title",
            "label": "Section Title",
            "default": "FOLLOW US ON SOCIAL MEDIA"
        },
        {
            "type": "range",
            "id": "title_font_size_desktop",
            "label": "Title Font Size (Desktop)",
            "min": 16,
            "max": 64,
            "step": 1,
            "unit": "px",
            "default": 32
        },
        {
            "type": "range",
            "id": "title_font_size_mobile",
            "label": "Title Font Size (Mobile)",
            "min": 16,
            "max": 48,
            "step": 1,
            "unit": "px",
            "default": 24
        },
        {
            "type": "select",
            "id": "title_font_weight",
            "label": "Title Font Weight",
            "default": "600",
            "options": [
                {"value": "300", "label": "Light"},
                {"value": "400", "label": "Regular"},
                {"value": "500", "label": "Medium"},
                {"value": "600", "label": "Semi-Bold"},
                {"value": "700", "label": "Bold"}
            ]
        },
        {
            "type": "header",
            "content": "Description Settings"
        },
        {
            "type": "textarea",
            "id": "instagram_des",
            "label": "Section Description",
            "default": "Share your moments with us and get featured!"
        },
        {
            "type": "range",
            "id": "description_font_size_desktop",
            "label": "Description Font Size (Desktop)",
            "min": 12,
            "max": 32,
            "step": 1,
            "unit": "px",
            "default": 16
        },
        {
            "type": "range",
            "id": "description_font_size_mobile",
            "label": "Description Font Size (Mobile)",
            "min": 12,
            "max": 24,
            "step": 1,
            "unit": "px",
            "default": 14
        },
        {
            "type": "select",
            "id": "description_font_weight",
            "label": "Description Font Weight",
            "default": "400",
            "options": [
                {"value": "300", "label": "Light"},
                {"value": "400", "label": "Regular"},
                {"value": "500", "label": "Medium"},
                {"value": "600", "label": "Semi-Bold"}
            ]
        },
        {
            "type": "header",
            "content": "Image Settings"
        },
        {
            "type": "range",
            "id": "image_size",
            "label": "Image Size (pixels)",
            "min": 150,
            "max": 400,
            "step": 10,
            "default": 250
        },
        {
            "type": "select",
            "id": "image_shape",
            "label": "Image Shape",
            "default": "square",
            "options": [
                {"value": "square", "label": "Square"},
                {"value": "circle", "label": "Circle"},
                {"value": "rounded", "label": "Rounded"}
            ]
        },
        {
            "type": "select",
            "id": "images_per_row",
            "label": "Images per Row",
            "default": "5",
            "options": [
                {"value": "2", "label": "2 Images"},
                {"value": "3", "label": "3 Images"},
                {"value": "4", "label": "4 Images"},
                {"value": "5", "label": "5 Images"},
                {"value": "6", "label": "6 Images"},
                {"value": "7", "label": "7 Images"},
                {"value": "8", "label": "8 Images"},
                {"value": "9", "label": "9 Images"},
                {"value": "10", "label": "10 Images"}
            ]
        },
        {
            "type": "range",
            "id": "instagram_item_limit",
            "label": "Maximum Items to Show",
            "min": 3,
            "max": 20,
            "step": 1,
            "default": 5
        },
        {
            "type": "range",
            "id": "grid_gap",
            "label": "Image Spacing",
            "min": 0,
            "max": 30,
            "step": 5,
            "default": 10
        },
        {
            "type": "range",
            "id": "scroll_speed",
            "label": "Scroll Speed (seconds)",
            "min": 10,
            "max": 60,
            "step": 5,
            "default": 20
        }
    ],
    "blocks": [
        {
            "type": "instagram",
            "name": "Instagram Post",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Image"
                },
                {
                    "type": "text",
                    "id": "instagram_url",
                    "label": "Instagram Post URL",
                    "info": "Full Instagram post URL"
                },
                {
                    "type": "text",
                    "id": "custom_link",
                    "label": "Custom Redirect URL",
                    "info": "Optional custom link"
                },
                {
                    "type": "text",
                    "id": "title",
                    "label": "Image Title (Optional)"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Instagram Feed",
            "blocks": [
                {"type": "instagram"},
                {"type": "instagram"},
                {"type": "instagram"}
            ]
        }
    ]
}
{% endschema %}